# ============================================================
# SINAUR-RDC — Variables d'environnement Railway
# Copie dans Railway Dashboard > Variables pour chaque service
# Génère les secrets: openssl rand -base64 32
# ============================================================

# ── SERVICE: api ────────────────────────────────────────────
# (Configurer dans le service "api" sur Railway)

NODE_ENV=production
DATABASE_URL=postgresql://neondb_owner:VOTRE_MOT_DE_PASSE@ep-xxx.eu-central-1.aws.neon.tech/neondb?sslmode=require
REDIS_URL=redis://default:VOTRE_MOT_DE_PASSE_REDIS@roundhouse.proxy.rlwy.net:PORT
JWT_SECRET=GENERER_AVEC_openssl_rand_base64_48
AI_SERVICE_URL=https://ai-prediction-VOTRE_ID.up.railway.app
AI_INTERNAL_API_KEY=GENERER_AVEC_openssl_rand_base64_32
LOG_LEVEL=info
API_PORT=3000
API_HOST=0.0.0.0

# SMS (optionnel — désactiver si pas de passerelle SMS)
SMS_GATEWAY_URL=
SMS_GATEWAY_API_KEY=
SMS_SENDER_ID=SINAUR

# Firebase (pour push notifications — optionnel)
FIREBASE_PROJECT_ID=sinaur-rdc
# FIREBASE_SERVICE_ACCOUNT_KEY=<base64 du JSON service account>


# ── SERVICE: ai-prediction ───────────────────────────────────
# (Configurer dans le service "ai-prediction" sur Railway)

DATABASE_URL=postgresql://neondb_owner:VOTRE_MOT_DE_PASSE@ep-xxx.eu-central-1.aws.neon.tech/neondb?sslmode=require
REDIS_URL=redis://default:VOTRE_MOT_DE_PASSE_REDIS@roundhouse.proxy.rlwy.net:PORT
INTERNAL_API_KEY=MEME_VALEUR_QUE_AI_INTERNAL_API_KEY_CI_DESSUS
LOG_LEVEL=INFO
ALERT_VALIDATION_REQUIRED=true


# ── SERVICE: command-center (build arg Vite) ──────────────────
# Renseigner dans Railway > service "command-center" > Settings > Build
# (ce n'est PAS une variable runtime, c'est une build arg)

VITE_API_BASE_URL=https://api-VOTRE_ID.up.railway.app
VITE_MAPLIBRE_STYLE_URL=https://demotiles.maplibre.org/style.json


# ── SERVICE: public (build arg Vite) ─────────────────────────
# Même logique que command-center

VITE_API_BASE_URL=https://api-VOTRE_ID.up.railway.app
VITE_MAPLIBRE_STYLE_URL=https://demotiles.maplibre.org/style.json


# ── SERVICE: alerting ────────────────────────────────────────

DATABASE_URL=postgresql://neondb_owner:VOTRE_MOT_DE_PASSE@ep-xxx.eu-central-1.aws.neon.tech/neondb?sslmode=require
REDIS_URL=redis://default:VOTRE_MOT_DE_PASSE_REDIS@roundhouse.proxy.rlwy.net:PORT
API_BASE_URL=https://api-VOTRE_ID.up.railway.app
AI_BASE_URL=https://ai-prediction-VOTRE_ID.up.railway.app
NODE_ENV=production
LOG_LEVEL=info


# ── SERVICE: ingestion ───────────────────────────────────────

DATABASE_URL=postgresql://neondb_owner:VOTRE_MOT_DE_PASSE@ep-xxx.eu-central-1.aws.neon.tech/neondb?sslmode=require
NODE_ENV=production
LOG_LEVEL=info


# ── GitHub Actions Secrets à configurer ─────────────────────
# Settings > Secrets > Actions > New repository secret

# RAILWAY_TOKEN        → Token API Railway (railway.app > Settings > Tokens)
# RAILWAY_SERVICE_API_ID        → ID du service "api" dans Railway
# RAILWAY_SERVICE_AI_ID         → ID du service "ai-prediction"
# RAILWAY_SERVICE_CC_ID         → ID du service "command-center"
# RAILWAY_SERVICE_PUBLIC_ID     → ID du service "public"
# RAILWAY_SERVICE_ALERTING_ID   → ID du service "alerting"
# RAILWAY_SERVICE_INGESTION_ID  → ID du service "ingestion"
# VITE_API_BASE_URL             → URL publique de l'API Railway (pour le build)
