{
  "name": "@sinaur/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:seed": "tsx src/db/seed.ts",
    "db:reset": "tsx src/db/reset.ts",
    "db:import-cod-ab": "tsx src/db/import-cod-ab.ts"
  },
  "dependencies": {
    "@sinaur/shared-types": "workspace:*",
    "fastify": "^4.28.0",
    "@fastify/jwt": "^8.0.0",
    "@fastify/cors": "^9.0.0",
    "@fastify/helmet": "^11.1.1",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/multipart": "^8.3.0",
    "@fastify/swagger": "^8.14.0",
    "@fastify/swagger-ui": "^4.0.0",
    "@fastify/websocket": "^8.3.1",
    "postgres": "^3.4.4",
    "ioredis": "^5.3.2",
    "bcrypt": "^5.1.1",
    "jose": "^5.9.3",
    "zod": "^3.23.8",
    "ulid": "^2.3.0",
    "pino": "^9.3.2",
    "pino-pretty": "^11.2.2"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/node": "^20.0.0",
    "tsx": "^4.16.2",
    "typescript": "^5.5.0",
    "vitest": "^2.0.4"
  }
}
