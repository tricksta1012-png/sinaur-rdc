# ─── Base de données ─────────────────────────────────────────────────────────
DATABASE_URL=postgresql://sinaur:sinaur_secret@localhost:5432/sinaur_rdc
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=20

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Auth JWT ────────────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_strong_random_secret_min_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── API ──────────────────────────────────────────────────────────────────────
API_PORT=3000
API_HOST=0.0.0.0
API_BASE_URL=http://localhost:3000

# ─── Frontend ─────────────────────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:3000
VITE_MAPLIBRE_STYLE_URL=https://demotiles.maplibre.org/style.json

# ─── Firebase (FCM push notifications uniquement) ────────────────────────────
FIREBASE_PROJECT_ID=sinaur-rdc
FIREBASE_SERVICE_ACCOUNT_PATH=/secrets/firebase-service-account.json
# FIREBASE_SERVICE_ACCOUNT_KEY= (alternativement : clé JSON encodée en base64)

# ─── Service IA ───────────────────────────────────────────────────────────────
AI_SERVICE_URL=http://localhost:8000
AI_SERVICE_API_KEY=
AUTO_ALERT_SCORE_THRESHOLD=75

# ─── Service Alerting ─────────────────────────────────────────────────────────
ALERTING_SERVICE_URL=http://localhost:3001

# ─── SMS / USSD (passerelle) ──────────────────────────────────────────────────
SMS_GATEWAY_URL=
SMS_GATEWAY_API_KEY=
SMS_SENDER_ID=SINAUR

# ─── ReliefWeb API ────────────────────────────────────────────────────────────
RELIEFWEB_API_URL=https://api.reliefweb.int/v1
RELIEFWEB_APP_NAME=sinaur-rdc

# ─── Logs / Observabilité ─────────────────────────────────────────────────────
LOG_LEVEL=info
NODE_ENV=development
# SWAGGER_ENABLED=true  # Activer la doc OpenAPI en production (risque : exposition API)

# ─── Production uniquement (docker-compose.prod.yml) ─────────────────────────
# POSTGRES_PASSWORD=<strong-password>
# REDIS_PASSWORD=<strong-password>
# GRAFANA_ADMIN_PASSWORD=<strong-password>
# GRAFANA_ROOT_URL=https://grafana.sinaur-rdc.cd
# REGISTRY=ghcr.io
# IMAGE_OWNER=sinaur-rdc
# IMAGE_TAG=v1.0.0
# API_PORT_HOST=127.0.0.1:3000
# SYNC_PORT_HOST=127.0.0.1:3003
# USSD_PORT_HOST=127.0.0.1:3002
# CC_PORT_HOST=127.0.0.1:8081
# PROM_PORT_HOST=127.0.0.1:9090
# GRAFANA_PORT_HOST=127.0.0.1:3500
