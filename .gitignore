# Dependencies
node_modules/
.pnpm-store/

# Build outputs
dist/
build/
.next/
out/

# Environment (NEVER commit secrets)
.env
.env.local
.env.*.local

# Turbo cache
.turbo/

# IDE
.vscode/settings.json
.idea/
*.swp

# OS
.DS_Store
Thumbs.db

# Logs
logs/
*.log
npm-debug.log*
docker-public-build*.log.err

# TypeScript artefacts compilés en src/ (tsc sans outDir séparé)
apps/*/src/**/*.js
apps/*/src/**/*.js.map
apps/*/src/**/*.d.ts
apps/*/src/**/*.d.ts.map

# Claude Code (mémoire locale)
.claude/

# Dockerfile racine — artefact de test Railway, non utilisé
/Dockerfile

# Test coverage
coverage/
.nyc_output/

# Python
__pycache__/
*.pyc
.venv/
*.egg-info/

# Docker volumes (local dev)
infra/volumes/

# Certificats SSL — ne jamais versionner les clés privées
infra/certs/*.key
infra/certs/*.pem
infra/certs/*.crt
!infra/certs/.gitkeep

# Secrets de déploiement
infra/secrets/
.env.prod

# Tiles cache
apps/mobile/tiles-cache/
